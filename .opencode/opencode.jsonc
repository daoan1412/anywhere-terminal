{
  "$schema": "https://opencode.ai/config.json",
  "plugin": [
    "@franlol/opencode-md-table-formatter@latest"
  ],
  "permission": {
    "question": "allow"
  },
  "agent": {
    "asm-review-contracts": {
      "model": "openai/gpt-5.4",
      "reasoningEffort": "high"
    },
    "asm-review-data-security": {
      "model": "openai/gpt-5.5",
      "reasoningEffort": "high"
    },
    "asm-review-frontend": {
      "model": "openai/gpt-5.4-mini",
      "reasoningEffort": "high"
    },
    "asm-review-logic": {
      "model": "openai/gpt-5.3-codex",
      "reasoningEffort": "high"
    },
    "asm-librarian": {
      "model": "openai/gpt-5.4-mini"
    },
    "asm-knowledge-extract": {
      "model": "openai/gpt-5.4-mini"
    },
    "asm-finder": {
      "model": "other/qwen3.5-plus"
    },
    "asm-oracle": {
      "model": "openai/gpt-5.5",
      "reasoningEffort": "high"
    },
    "asm-review-master": {
      "model": "openai/gpt-5.5"
    },
    "asm-review-performance": {
      "model": "openai/gpt-5.5",
      "reasoningEffort": "high"
    }
  },
  "mcp": {
    "code-review-graph": {
      "type": "local",
      "command": [
        "uvx",
        "code-review-graph",
        "serve"
      ]
    },
    "deepwiki": {
      "type": "remote",
      "url": "https://mcp.deepwiki.com/mcp"
    },
    "gh_grep": {
      "type": "remote",
      "url": "https://mcp.grep.app"
    }
  },
  "model": "openai/gpt-5.4",
  "small_model": "openai/gpt-5.4-mini"
}
